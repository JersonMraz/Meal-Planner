generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Favorite {
  id      Int @id @default(autoincrement())
  user_id Int
  meal_id Int
  Meal    Meal   @relation(fields: [meal_id], references: [id])
  User    User   @relation(fields: [user_id], references: [id])
}

model Ingredients {
  id      Int @id @default(autoincrement())
  meal_id Int
  name    String
  Meal    Meal   @relation(fields: [meal_id], references: [id])
}

model Instructions {
  id          Int @id @default(autoincrement())
  meal_id     Int
  step_number Int
  description String
  Meal        Meal   @relation(fields: [meal_id], references: [id])
}

model Meal {
  id           Int @id @default(autoincrement())
  name         String
  image_url    String?
  category     String
  cuisine      String
  diet_type    String
  prep_time    Int
  cook_time    Int
  Favorite     Favorite[]
  Ingredients  Ingredients[]
  Instructions Instructions[]
  Meal_Tags    Meal_Tags[]
  Nutrition    Nutrition?
  MealPlan     MealPlan[]
}

model Meal_Tags {
  meal_id Int
  tag_id  Int
  Meal    Meal   @relation(fields: [meal_id], references: [id])
  Tags    Tags   @relation(fields: [tag_id], references: [id])

  @@id([meal_id, tag_id])
}

model Nutrition {
  id       Int @id @default(autoincrement())
  meal_id  Int @unique
  calories Int
  protein  Int
  carbs    Int
  fat      Int
  Meal     Meal   @relation(fields: [meal_id], references: [id])
}

model Tags {
  id        Int @id @default(autoincrement())
  name      String @unique
  Meal_Tags Meal_Tags[]
}

model User {
  id        Int @id @default(autoincrement())
  firstname String
  lastname  String
  email     String     @unique
  password  String
  bio       String?
  profile_picture String?
  role      String     @default("USER")
  createdAt DateTime   @default(now())
  Favorite    Favorite[]
  MealPlan    MealPlan[]
  GroceryItem GroceryItem[]
  dietaryPreferences DietaryPreferences?
  notificationSettings NotificationSettings?
  languageAndRegion LanguageAndRegion?
  Notifications Notifications[]
}

model DietaryPreferences {
  user_id    Int @id
  default_diet  String? @default("No restrictions")
  allergens  String[]
  favorite_cuisines   String[]
  calorieGoal Int? 
  User User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Notifications {
  id          Int @id @default(autoincrement())
  user_id     Int
  type        String
  title       String
  description String
  icon String
  icon_class String
  link String?
  is_read     Boolean @default(false)
  created_at  DateTime @default(now())
  User        User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  user_id     Int @id
  meal_reminders Boolean @default(true)
  grocery_reminders Boolean @default(true)
  weekly_digest Boolean @default(false)
  product_updates Boolean @default(false)
  push_enabled Boolean @default(true)
  email_enabled Boolean @default(true)
  reminder_time String @default("18:00")
  User User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model LanguageAndRegion {
  user_id    Int @id
  language String @default("English")
  region String @default("United States")
  weekStart String @default("monday")
  User User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        Int    @id @default(autoincrement())
  user_id   Int
  date      String
  meal_type String
  meal_id   Int
  Meal      Meal   @relation(fields: [meal_id], references: [id])
  User      User   @relation(fields: [user_id], references: [id])

  @@unique([user_id, date, meal_type])
}

model GroceryItem {
  id           Int      @id @default(autoincrement())
  user_id      Int
  category     String
  name         String
  checked      Boolean  @default(false)
  meal_plan_id Int?
  User         User     @relation(fields: [user_id], references: [id])
}
